  DB.devices.forEach(d=>{
    if(d.estado==='DESHABILITADO') A.push({sev:'alarm',t:`Dispositivo deshabilitado · ${d.dir}`,d:`${d.ubic} (${d.nivel}) · Motivo panel: ${d.motivo||'sin registrar'} · Requiere gestión con mantenimiento SDI.`});
    if(d.nov && d.estado!=='DESHABILITADO') A.push({sev:'warn',t:`Novedad abierta · ${d.dir}`,d:`${d.ubic} (${d.nivel}) · "${d.nov}". Verificar y gestionar cierre.`});
    if(/CERRADO|LLAVE/i.test(d.nov||'')) A.push({sev:'info',t:`Acceso bloqueado · ${d.dir}`,d:`${d.ubic}: cuarto cerrado sin llaves. Escalar a Coordinación de Seguridad para gestión de llaves maestras.`});
    if(d.insp){
      const ds=daysSince(d.insp);
      if(ds>DB.params.periodo) A.push({sev:'alarm',t:`Inspección vencida · ${d.dir}`,d:`Última inspección hace ${ds} días (periodicidad ${DB.params.periodo}). ${d.ubic}.`});
      else if(ds>DB.params.periodo-DB.params.umbral) A.push({sev:'warn',t:`Inspección próxima a vencer · ${d.dir}`,d:`Vence en ${DB.params.periodo-ds} días. ${d.ubic}.`});
    }
  });
  // Integridad: descuadre consolidado vs niveles (imposible internamente, pero validamos duplicados)
  const seen={}; let dups=0;
  DB.devices.forEach(d=>{ if(d.dir!=='FUENTE'){ if(seen[d.dir]) dups++; seen[d.dir]=1; }});
  if(dups) A.push({sev:'alarm',t:'Integridad: direcciones duplicadas',d:`${dups} direcciones lógicas repetidas en el inventario. Depurar de inmediato.`});
  const sinVerif=DB.devices.filter(d=>!d.verif).length;
  if(sinVerif) A.push({sev:'info',t:`${sinVerif} dispositivos sin verificar`,d:'Programe rondas de verificación por nivel desde el módulo Verificación.'});
  return A;
}
function renderAlerts(){
  const A=computeAlerts();
  $('alertList').innerHTML = A.length? A.map(a=>`<div class="alertItem sev${a.sev==='alarm'?'Alarm':a.sev==='info'?'Info':''}">
      <span class="led ${a.sev==='alarm'?'alarm':a.sev==='info'?'off':'warn'}" style="margin-top:4px"></span>
      <div><div class="aT">${esc(a.t)}</div><div class="aD">${esc(a.d)}</div></div></div>`).join('')
    : '<div class="card" style="color:var(--ok)">✔ Sin alertas activas. Sistema en condición normal.</div>';
}
function refreshBadge(){
  const n=computeAlerts().filter(a=>a.sev!=='info').length;
  const b=$('alertBadge'); b.style.display=n?'':'none'; b.textContent=n;
}

/* ---------- Bitácora ---------- */
function renderLog(){
  const q=($('logQ').value||'').toUpperCase();
  const rows=DB.log.filter(l=>!q||((l.t+l.u+l.a+l.d).toUpperCase().includes(q))).slice(0,400);
  $('logList').innerHTML= rows.length? rows.map(l=>`<div class="logRow"><span class="lw">${l.t}</span><span class="lw">${esc(l.u)}</span><b style="font-size:11px">${esc(l.a)}</b><span>${esc(l.d)}</span></div>`).join('')
    : '<div style="padding:20px;color:var(--muted)">Sin registros que coincidan.</div>';
}
function exportLog(){ download('bitacora_sdi_nogal.json', JSON.stringify(DB.log,null,1)); }

/* ---------- Configuración ---------- */
function renderConf(){
  const admin=S.user.rol==='ADMINISTRADOR';
  renderCat('catMotivos','motivos',admin); renderCat('catNovedades','novedades',admin); renderCat('catResp','responsables',admin);
  $('cfgPeriodo').value=DB.params.periodo; $('cfgUmbral').value=DB.params.umbral;
  $('cfgPeriodo').disabled=$('cfgUmbral').disabled=!admin;
  const s=stats();
  $('integInfo').innerHTML=`Inventario actual: <b>${s.t}</b> dispositivos (${s.det} detectores + ${s.mod} módulos).<br>
    Semilla original libro 2016: <b>885</b> (884 del CONSOLIDADO + 1 detector L02D152 P6 registrado solo en hoja NIVEL 6, marcado DESMONTADO).<br>
    Usuarios registrados: ${DB.users.length} · Rondas cerradas: ${DB.rondas.length} · Registros de bitácora: ${DB.log.length}.`;
  renderUsers(admin);
  renderFsStatus();
}
function renderUsers(admin){
  $('userAdmin').innerHTML = DB.users.map((u,i)=>`
    <div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--line);flex-wrap:wrap">
      <span style="flex:1;min-width:150px"><b>${esc(u.nom)}</b><div style="font-size:11px;color:var(--muted)">${esc(u.mail)}</div></span>
      ${admin? `<select onchange="setRol(${i},this.value)" ${u.mail===S.user.mail?'disabled title="No puede cambiar su propio rol"':''}>
          ${['ADMINISTRADOR','SUPERVISOR','CONSULTA'].map(r=>`<option ${u.rol===r?'selected':''}>${r}</option>`).join('')}</select>
        <button class="btn sm" title="Restablecer contraseña" onclick="resetPass(${i})">🔑</button>
        ${u.mail!==S.user.mail?`<button class="btn sm danger" title="Eliminar usuario" onclick="delUser(${i})">🗑</button>`:''}`
      : `<span class="pill nor">${u.rol}</span>`}
    </div>`).join('');
}
function setRol(i,rol){
  const u=DB.users[i];
  if(rol!=='ADMINISTRADOR' && u.rol==='ADMINISTRADOR' && DB.users.filter(x=>x.rol==='ADMINISTRADOR').length<=1){
    toast('Debe existir al menos un ADMINISTRADOR.','e'); renderUsers(true); return;
  }
  audit('USUARIOS',`Rol de ${u.mail}: ${u.rol} → ${rol}`); u.rol=rol; save(); toast('Rol actualizado: '+u.nom);
}
function resetPass(i){
  const u=DB.users[i];
  const nw=prompt('Nueva contraseña temporal para '+u.nom+' (mínimo 6 caracteres):','Elnogal2026');
  if(nw===null) return;
  if(nw.length<6) return toast('Mínimo 6 caracteres.','e');
  u.ph=hash(nw); audit('USUARIOS',`Contraseña restablecida para ${u.mail}`); save();
  toast('Contraseña restablecida para '+u.nom+'. Indíquele que la cambie en su primer ingreso.');
}
function delUser(i){
  const u=DB.users[i];
  if(u.rol==='ADMINISTRADOR' && DB.users.filter(x=>x.rol==='ADMINISTRADOR').length<=1) return toast('No puede eliminar al único ADMINISTRADOR.','e');
  if(!confirm('¿Eliminar la cuenta de '+u.nom+' ('+u.mail+')? La acción queda en bitácora.')) return;
  DB.users.splice(i,1); audit('USUARIOS',`Cuenta eliminada: ${u.mail}`); save(); renderUsers(true); toast('Usuario eliminado.','w');
}
function renderCat(el,key,admin){
  $(el).innerHTML=DB.cat[key].map((m,i)=>`<span class="chip">${esc(m)}${admin?`<button onclick="rmCat('${key}',${i})">×</button>`:''}</span>`).join('');
}
function addCat(key,inputId){
  if(S.user.rol!=='ADMINISTRADOR') return toast('Solo ADMINISTRADOR modifica catálogos.','e');
  const v=$(inputId).value.trim().toUpperCase(); if(!v) return;
  if(DB.cat[key].includes(v)) return toast('Ya existe en el catálogo.','w');
  DB.cat[key].push(v); $(inputId).value=''; audit('CONFIG',`Catálogo ${key}: añadido "${v}"`); save(); renderConf();
}
function rmCat(key,i){
  const v=DB.cat[key][i];
  if(!confirm('¿Eliminar del catálogo: '+v+'?')) return;
  DB.cat[key].splice(i,1); audit('CONFIG',`Catálogo ${key}: eliminado "${v}"`); save(); renderConf();
}
function setParam(){
  if(S.user.rol!=='ADMINISTRADOR') return;
  DB.params.periodo=Math.max(7,+$('cfgPeriodo').value||180);
  DB.params.umbral=Math.max(1,+$('cfgUmbral').value||30);
  audit('CONFIG',`Parámetros: periodicidad ${DB.params.periodo}d, umbral ${DB.params.umbral}d`); save(); toast('Parámetros guardados.');
}
function restoreSeed(){
  if(!confirm('¿Restaurar el dataset semilla original (885 dispositivos del libro DETECTORES 2016)?\nSe perderán los cambios de inventario actuales (usuarios y bitácora se conservan).')) return;
  DB.devices=JSON.parse(JSON.stringify(SEED));
  audit('DATOS','Dataset semilla restaurado (885 dispositivos, libro 2016)'); save();
  toast('Semilla restaurada: 885 dispositivos.'); go(S.view);
}
function wipeAll(){
  if(!confirm('RESETEO TOTAL: elimina usuarios, inventario, bitácora, rondas y configuración de este navegador. ¿Continuar?')) return;
  if(!confirm('Confirmación final. Esta acción es irreversible.')) return;
  localStorage.removeItem(LS); sessionStorage.removeItem('sdi_ses'); location.reload();
}

/* ---------- Export / Import / Print ---------- */
function download(name, content, mime='application/json'){
  const b=new Blob([content],{type:mime}); const a=document.createElement('a');
  a.href=URL.createObjectURL(b); a.download=name; a.click(); URL.revokeObjectURL(a.href);
}
function exportCSV(){
  const cols=['dir','lazo','cat','tipo','flash','label','ubic','obs','cbe','llamada','piso','torre','nivel','estado','motivo','nov','verif','resp','insp','emp'];
  const head=cols.join(';');
  const rows=filtered().map(d=>cols.map(c=>'"'+String(c==='verif'?(d.verif?'SI':'NO'):(d[c]??'')).replace(/"/g,'""')+'"').join(';'));
  download('inventario_sdi_nogal.csv','\uFEFF'+head+'\n'+rows.join('\n'),'text/csv');
  audit('EXPORT','Exportación CSV: '+rows.length+' registros');
}
function exportJSON(){
  download('inventario_sdi_nogal.json', JSON.stringify(filtered(),null,1));
  audit('EXPORT','Exportación JSON del inventario filtrado');
}
function importJSON(){
  if(S.user.rol!=='ADMINISTRADOR') return toast('Solo ADMINISTRADOR importa datos.','e');
  $('fileImp').onchange=e=>{
    const f=e.target.files[0]; if(!f) return;
    const r=new FileReader();
    r.onload=()=>{
      try{
        const data=JSON.parse(r.result);
        if(!Array.isArray(data)||!data.every(d=>d.dir&&d.tipo)) throw new Error('Esquema inválido: se requiere arreglo de dispositivos con campos dir y tipo.');
        if(!confirm(`El archivo contiene ${data.length} dispositivos. Vista previa del primero:\n${data[0].dir} · ${data[0].tipo} · ${data[0].ubic||''}\n\n¿Reemplazar el inventario actual?`)) return;
        DB.devices=data; audit('DATOS',`Importación JSON: ${data.length} dispositivos`); save();
        toast('Inventario importado: '+data.length+' dispositivos.'); go(S.view);
      }catch(err){ toast('Importación rechazada: '+err.message,'e'); }
      e.target.value='';
    };
    r.readAsText(f);
  };
  $('fileImp').click();
}
function printReport(){ $('prDate').textContent=now(); window.print(); }

