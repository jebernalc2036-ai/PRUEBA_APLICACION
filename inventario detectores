function saveForm(){
  const E=$('fErr'); E.textContent='';
  const dir=$('fDir').value.trim().toUpperCase().replace(/\s+/g,' ');
  const tipo=$('fTipoM').value, ubic=$('fUbic').value.trim(), est=$('fEst').value, mot=$('fMot').value;
  if(!dir||!tipo||!ubic) return E.textContent='Dirección, Type Code y Ubicación son obligatorios.';
  const m=dir.match(/^(L0?[1-6])([DM])(\d{1,3})\s+(P-?\d{1,2}B?|N-1|ESCA)$/);
  if(!m && dir!=='FUENTE') return E.textContent='Formato de dirección inválido. Ejemplo válido: L03D145 P3 · L01M001 P12B';
  if(est==='DESHABILITADO' && !mot) return E.textContent='Un dispositivo DESHABILITADO requiere motivo (catálogo del panel).';
  const dup=DB.devices.find(x=>x.dir===dir && x.id!==editingId);
  if(dup && dir!=='FUENTE') return E.textContent='Dirección duplicada: ya existe '+dir+' ('+dup.ubic+').';
  let lazo='PANEL',cat='MODULO',piso='-',torre='-',nivel='GENERAL';
  if(m){
    lazo='L0'+m[1].replace('L','').replace('0',''); cat=m[2]==='D'?'DETECTOR':'MODULO';
    const pr=m[4]; torre=pr.endsWith('B')?'B':(pr==='ESCA'?'-':'A');
    if(pr==='N-1') piso='P-1';
    else if(pr==='ESCA') piso='ESCA';
    else piso='P'+parseInt(pr.replace('P','').replace('B',''),10);
    const NM={'P-1':'NIVEL -1','P1':'NIVEL 1','P2':'NIVEL 2','P3':'NIVEL 3','P4':'NIVEL 4','P5':'NIVEL 5','P6':'NIVEL 6','P7':'NIVEL 7','P8':'NIVEL 8','P9':'NIVEL 9','P10':'NIVEL 10','P11':'NIVEL 11','P12':'NIVEL 12','P13':'CUBIERTA'};
    nivel=NM[piso]||'GENERAL';
  }
  const rec={ id: editingId||dir+'|'+Date.now(), dir, lazo, cat, tipo, flash:$('fFlash').value,
    label:$('fLabel').value.trim(), ubic, obs:$('fObs').value.trim(), cbe:$('fCbe').value.trim().toUpperCase(),
    llamada:$('fLlam').value.trim(), piso, torre, nivel, estado:est, motivo:est==='DESHABILITADO'?mot:'',
    nov:$('fNovS').value, verif:false, resp:$('fResp').value, insp:$('fInsp').value, emp:$('fEmp').value.trim() };
  if(editingId){
    const i=DB.devices.findIndex(x=>x.id===editingId); const old=DB.devices[i];
    rec.verif=old.verif; DB.devices[i]=rec;
    audit('EDICIÓN',`${dir}: cambios guardados (estado ${old.estado}→${rec.estado}${rec.nov?`, novedad "${rec.nov}"`:''})`);
    toast('Dispositivo actualizado: '+dir);
  }else{
    DB.devices.push(rec); audit('ALTA',`Nuevo dispositivo ${dir} · ${tipo} · ${ubic}`); toast('Dispositivo creado: '+dir);
  }
  save(); closeForm(); buildInvControls(); renderInv(); refreshBadge();
}
function delDev(id){
  const d=DB.devices.find(x=>x.id===id); if(!d) return;
  if(!confirm(`¿Eliminar definitivamente ${d.dir} (${d.ubic})?\nEsta acción queda registrada en la bitácora.`)) return;
  if(!confirm('Confirmación final: la eliminación no puede deshacerse salvo restaurando la semilla o un respaldo.')) return;
  DB.devices=DB.devices.filter(x=>x.id!==id);
  audit('BAJA',`Eliminado ${d.dir} · ${d.ubic}`); save(); toast('Dispositivo eliminado: '+d.dir,'w');
  buildInvControls(); renderInv(); refreshBadge();
}

/* ---------- Dashboard ---------- */
function stats(){
  const D=DB.devices;
  const t=D.length, det=D.filter(d=>d.cat==='DETECTOR').length, mod=t-det;
  const hab=D.filter(d=>d.estado==='HABILITADO').length, des=t-hab;
  const ver=D.filter(d=>d.verif).length, nov=D.filter(d=>d.nov).length;
  const critProb=D.filter(d=>critOf(d)==='ALTA'&&(d.estado==='DESHABILITADO'||d.nov)).length;
  const venc=D.filter(d=>d.insp && daysSince(d.insp)>DB.params.periodo).length;
  return {t,det,mod,hab,des,ver,nov,critProb,venc};
}
function daysSince(iso){ return Math.floor((Date.now()-new Date(iso).getTime())/86400000); }
