let editingId=null;
function nextAddr(){
  // Sugiere la próxima dirección disponible del lazo con menor carga
  const cnt={}; DB.devices.forEach(d=>cnt[d.lazo]=(cnt[d.lazo]||0)+1);
  const L=['L01','L02','L03','L04','L05','L06'].sort((a,b)=>(cnt[a]||0)-(cnt[b]||0))[0];
  const nums=DB.devices.filter(d=>d.lazo===L&&/D/.test(d.dir)).map(d=>{const m=d.dir.match(/D(\d+)/);return m?+m[1]:0;});
  const nx=(nums.length?Math.max(...nums):0)+1;
  return `${L}D${String(nx).padStart(3,'0')} P1`;
}
