/* =====================================================================
   MOTOR DE ARCHIVO COMPARTIDO (OneDrive / carpeta sincronizada)
   - El HTML se abre desde la carpeta OneDrive sincronizada de cada equipo.
   - Los datos viven en SDI_DATOS_NOGAL.json junto al HTML; OneDrive lo
     replica a todos los equipos autorizados del Club.
   - Control de revisiones (rev) con última escritura gana + verificación
     previa de cambios remotos para minimizar pérdidas por concurrencia.
   - El handle del archivo se conserva en IndexedDB para reconexión
     automática en próximos ingresos del mismo equipo.
   ===================================================================== */
const FS = { handle:null, rev:0, connected:false, writing:false, pend:null };
const FS_SUPPORT = typeof window !== 'undefined' && 'showOpenFilePicker' in window;

/* --- IndexedDB mínimo para persistir el handle del archivo --- */
function idb(){ return new Promise((res,rej)=>{ const r=indexedDB.open('sdi_nogal_fs',1);
  r.onupgradeneeded=()=>r.result.createObjectStore('kv');
  r.onsuccess=()=>res(r.result); r.onerror=()=>rej(r.error); }); }
async function idbSet(k,v){ const d=await idb(); return new Promise((res,rej)=>{ const t=d.transaction('kv','readwrite'); t.objectStore('kv').put(v,k); t.oncomplete=res; t.onerror=()=>rej(t.error); }); }
async function idbGet(k){ const d=await idb(); return new Promise((res,rej)=>{ const t=d.transaction('kv','readonly'); const q=t.objectStore('kv').get(k); q.onsuccess=()=>res(q.result); q.onerror=()=>rej(q.error); }); }
async function idbDel(k){ const d=await idb(); return new Promise((res,rej)=>{ const t=d.transaction('kv','readwrite'); t.objectStore('kv').delete(k); t.oncomplete=res; t.onerror=()=>rej(t.error); }); }

function syncUI(state, txt){
  const led=$('syncLed'), t=$('syncTxt');
  if(!led) return;
  led.className='led '+state; t.textContent=txt;
}
function syncChipClick(){
  if(FS.connected) checkRemote(true);
  else if(FS_SUPPORT) reconnectFromIDB(true);
  else toast('Este navegador no soporta archivo compartido. Use Microsoft Edge o Google Chrome.','w');
}

async function fileRead(){
  const f = await FS.handle.getFile();
  const txt = await f.text();
  if(!txt.trim()) return null;
  const j = JSON.parse(txt);
  if(!j || j.fmt!=='SDI_NOGAL' || !j.db || !Array.isArray(j.db.devices)) throw new Error('El archivo no tiene el formato de datos SDI del Club.');
  return j;
}
async function fileWrite(){
  if(!FS.connected || FS.writing) { if(FS.connected) FS.pend=true; return; }
  FS.writing=true;
  try{
    // Verificación de concurrencia: si otro usuario escribió una revisión
    // más nueva desde nuestra última lectura, adoptamos la remota primero.
    let remote=null;
    try{ remote = await fileRead(); }catch(e){}
    if(remote && remote.rev > FS.rev){
      adoptRemote(remote);
      toast('Se detectaron cambios de '+(remote.by||'otro usuario')+'; se cargaron antes de guardar. Verifique y repita su último cambio si no quedó aplicado.','w');
      FS.writing=false; return;
    }
    FS.rev++;
    const payload = { fmt:'SDI_NOGAL', ver:1, rev:FS.rev, updated:now(), by:S.user?S.user.mail:'—', db:DB };
    const w = await FS.handle.createWritable();
    await w.write(JSON.stringify(payload));
    await w.close();
    syncUI('ok','☁ Sincronizado · rev '+FS.rev);
  }catch(e){
    syncUI('warn','☁ Error al guardar'); toast('No se pudo escribir el archivo compartido: '+e.message,'e');
  }
  FS.writing=false;
  if(FS.pend){ FS.pend=false; scheduleWrite(); }
}
let wTimer=null;
function scheduleWrite(){ if(!FS.connected) return; clearTimeout(wTimer); wTimer=setTimeout(fileWrite, 800); }

function adoptRemote(remote){
  DB = remote.db; FS.rev = remote.rev;
  try{ localStorage.setItem(LS, JSON.stringify(DB)); }catch(e){}
  if(S.user){
    // Revalidar que la cuenta activa siga existiendo tras adoptar datos remotos
    const u=DB.users.find(x=>x.mail===S.user.mail);
    if(!u){ toast('Su cuenta fue modificada por un administrador. Vuelva a iniciar sesión.','w'); doLogout(); return; }
    S.user={nom:u.nom,mail:u.mail,rol:u.rol};
    go(S.view); // re-render de la vista actual con los datos nuevos
  }
  syncUI('ok','☁ Sincronizado · rev '+FS.rev);
}
async function checkRemote(manual){
  if(!FS.connected) { if(manual) toast('No hay archivo compartido conectado.','w'); return; }
  try{
    const remote = await fileRead();
    if(remote && remote.rev > FS.rev){ adoptRemote(remote); if(manual) toast('Datos actualizados desde el archivo compartido (rev '+remote.rev+').'); }
    else if(manual) toast('Ya tiene la última revisión ('+FS.rev+').');
  }catch(e){ if(manual) toast('No se pudo leer el archivo compartido: '+e.message,'e'); }
}

async function afterConnect(fromCreate){
  FS.connected=true;
  await idbSet('handle', FS.handle);
  if(fromCreate){ FS.rev=0; await fileWrite(); }
  else{
    const remote = await fileRead();
    if(remote){
      if(!confirm('Archivo de datos conectado (rev '+remote.rev+', última escritura: '+(remote.by||'—')+' '+(remote.updated||'')+').\n\n¿Adoptar los datos del archivo compartido? (Aceptar = usar datos compartidos · Cancelar = mantener los locales y sobrescribir el archivo)')){
        FS.rev = remote.rev; await fileWrite();
      } else { adoptRemote(remote); }
    } else { FS.rev=0; await fileWrite(); }
  }
  audit('SINCRONIZACIÓN','Archivo de datos compartido conectado en este equipo');
  syncUI('ok','☁ Sincronizado · rev '+FS.rev);
  renderFsStatus(); toast('Sincronización OneDrive activa en este equipo.');
}
async function connectExisting(){
  if(!FS_SUPPORT) return toast('Use Microsoft Edge o Google Chrome para el modo compartido.','e');
  try{
    const [h] = await window.showOpenFilePicker({types:[{description:'Datos SDI Nogal',accept:{'application/json':['.json']}}]});
    if((await h.queryPermission({mode:'readwrite'}))!=='granted') await h.requestPermission({mode:'readwrite'});
    FS.handle=h; await afterConnect(false);
  }catch(e){ if(e.name!=='AbortError') toast('Conexión cancelada o fallida: '+e.message,'w'); }
}
async function createDataFile(){
  if(!FS_SUPPORT) return toast('Use Microsoft Edge o Google Chrome para el modo compartido.','e');
  if(S.user.rol!=='ADMINISTRADOR') return toast('Solo ADMINISTRADOR crea el archivo de datos.','e');
  try{
    const h = await window.showSaveFilePicker({suggestedName:'SDI_DATOS_NOGAL.json',types:[{description:'Datos SDI Nogal',accept:{'application/json':['.json']}}]});
    FS.handle=h; await afterConnect(true);
  }catch(e){ if(e.name!=='AbortError') toast('Creación cancelada o fallida: '+e.message,'w'); }
}
async function disconnectFile(){
  if(!FS.connected && !(await idbGet('handle'))) return toast('No hay archivo conectado.','w');
  if(!confirm('¿Desconectar el archivo compartido en este equipo? La app seguirá funcionando solo con datos locales de este navegador.')) return;
  FS.handle=null; FS.connected=false; FS.rev=0; await idbDel('handle');
  audit('SINCRONIZACIÓN','Archivo compartido desconectado en este equipo');
  syncUI('off','Solo local'); renderFsStatus(); toast('Modo solo local activado.','w');
}
async function reconnectFromIDB(interactive){
  if(!FS_SUPPORT) return false;
  try{
    const h = await idbGet('handle');
    if(!h) { if(interactive) toast('No hay archivo recordado en este equipo. Conéctelo desde Configuración.','w'); return false; }
    let p = await h.queryPermission({mode:'readwrite'});
    if(p!=='granted' && interactive) p = await h.requestPermission({mode:'readwrite'});
    if(p!=='granted'){ syncUI('warn','☁ Clic para reconectar'); return false; }
    FS.handle=h; FS.connected=true;
    const remote = await fileRead();
    if(remote) adoptRemote(remote); else { FS.rev=0; await fileWrite(); }
    syncUI('ok','☁ Sincronizado · rev '+FS.rev);
    renderFsStatus();
    return true;
  }catch(e){ syncUI('warn','☁ Clic para reconectar'); return false; }
}
function renderFsStatus(){
  const el=$('fsStatus'); if(!el) return;
  el.innerHTML = FS_SUPPORT
    ? (FS.connected? `Estado: <b style="color:var(--ok)">CONECTADO</b> · revisión actual <b>${FS.rev}</b>. Guardado automático activo; los cambios de otros equipos se detectan cada 20 segundos y al volver a esta ventana.`
                   : `Estado: <b style="color:var(--warn)">SOLO LOCAL</b>. Conecte el archivo SDI_DATOS_NOGAL.json de la carpeta OneDrive compartida para que todo el equipo trabaje sobre los mismos datos.`)
    : 'Este navegador no soporta el modo de archivo compartido (File System Access). Use <b>Microsoft Edge</b> o <b>Google Chrome</b> en los equipos autorizados.';
}
