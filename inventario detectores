/* --- Renderizadores SVG nativos --- */
function svgBars(data, colorFn, w=420, rowH=20){
  const max=Math.max(...data.map(d=>d.v),1), lw=118, bw=w-lw-46;
  const h=data.length*rowH+6;
  return `<svg viewBox="0 0 ${w} ${h}" style="width:100%;height:auto" role="img">`+data.map((d,i)=>{
    const y=i*rowH+4, bwv=Math.max(2,bw*d.v/max);
    return `<text x="${lw-6}" y="${y+11}" text-anchor="end" fill="#8fa0ae" font-size="10.5">${esc(d.k)}</text>
      <rect x="${lw}" y="${y+2}" width="${bwv}" height="${rowH-9}" rx="2" fill="${colorFn(d,i)}"></rect>
      <text x="${lw+bwv+5}" y="${y+11}" fill="#e8edf1" font-size="10.5" font-family="var(--mono)">${d.v}</text>`;
  }).join('')+'</svg>';
}
function svgDonut(parts, size=150){
  const tot=parts.reduce((a,p)=>a+p.v,0)||1; let a0=-Math.PI/2; const cx=size/2,cy=size/2,R=size/2-6,r=R-22;
  let paths='';
  parts.forEach(p=>{
    const a1=a0+2*Math.PI*p.v/tot;
    const x0=cx+R*Math.cos(a0),y0=cy+R*Math.sin(a0),x1=cx+R*Math.cos(a1),y1=cy+R*Math.sin(a1);
    const xi=cx+r*Math.cos(a1),yi=cy+r*Math.sin(a1),xj=cx+r*Math.cos(a0),yj=cy+r*Math.sin(a0);
    const big=(a1-a0)>Math.PI?1:0;
    if(p.v>0) paths+=`<path d="M${x0} ${y0} A${R} ${R} 0 ${big} 1 ${x1} ${y1} L${xi} ${yi} A${r} ${r} 0 ${big} 0 ${xj} ${yj} Z" fill="${p.c}"><title>${esc(p.k)}: ${p.v}</title></path>`;
    a0=a1;
  });
  return `<div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap"><svg viewBox="0 0 ${size} ${size}" style="width:${size}px">${paths}
    <text x="${cx}" y="${cy+4}" text-anchor="middle" fill="#e8edf1" font-size="17" font-weight="600">${tot}</text></svg>
    <div class="legendRow" style="flex-direction:column;align-items:flex-start;gap:5px">${parts.map(p=>`<span><i style="background:${p.c}"></i>${esc(p.k)} · <b>${p.v}</b> (${(100*p.v/tot).toFixed(1)}%)</span>`).join('')}</div></div>`;
}
function chNivel(){
  const c={}; DB.devices.forEach(d=>c[d.nivel]=(c[d.nivel]||0)+1);
  const data=NIVELES.filter(n=>c[n]).map(n=>({k:n,v:c[n]}));
  $('chNivel').innerHTML=svgBars(data,()=> 'var(--info)');
}
function chEstado(){
  const s=stats();
  $('chEstado').innerHTML=svgDonut([{k:'Habilitado y verificado',v:DB.devices.filter(d=>d.estado==='HABILITADO'&&d.verif).length,c:'#3fb27f'},
    {k:'Habilitado sin verificar',v:DB.devices.filter(d=>d.estado==='HABILITADO'&&!d.verif).length,c:'#f0a840'},
    {k:'Deshabilitado',v:s.des,c:'#e5484d'}]);
}
function chLazo(){
  const lz=['L01','L02','L03','L04','L05','L06','PANEL'].filter(L=>DB.devices.some(d=>d.lazo===L));
  const w=420,rowH=22,lw=60,bw=w-lw-46; const max=Math.max(...lz.map(L=>DB.devices.filter(d=>d.lazo===L).length),1);
  let out=`<svg viewBox="0 0 ${w} ${lz.length*rowH+6}" style="width:100%;height:auto">`;
  lz.forEach((L,i)=>{
    const hab=DB.devices.filter(d=>d.lazo===L&&d.estado==='HABILITADO').length;
    const des=DB.devices.filter(d=>d.lazo===L&&d.estado==='DESHABILITADO').length;
    const y=i*rowH+4, w1=bw*hab/max, w2=bw*des/max;
    out+=`<text x="${lw-6}" y="${y+12}" text-anchor="end" fill="#8fa0ae" font-size="11">${L}</text>
      <rect x="${lw}" y="${y+3}" width="${Math.max(1,w1)}" height="12" rx="2" fill="${LAZO_COLOR[L].replace('var(--','').replace(')','')==='lpanel'?'#8fa0ae':''}" style="fill:${LAZO_COLOR[L]}"><title>${L} habilitados: ${hab}</title></rect>
      ${des?`<rect x="${lw+w1+1}" y="${y+3}" width="${Math.max(2,w2)}" height="12" rx="2" fill="#e5484d"><title>${L} deshabilitados: ${des}</title></rect>`:''}
      <text x="${lw+w1+w2+6}" y="${y+13}" fill="#e8edf1" font-size="10.5">${hab+des}</text>`;
  });
  out+='</svg><div class="legendRow"><span><i style="background:#e5484d"></i>Segmento rojo = deshabilitados del lazo</span></div>';
  $('chLazo').innerHTML=out;
}
function chTipo(){
  const c={}; DB.devices.forEach(d=>c[d.tipo]=(c[d.tipo]||0)+1);
  const data=Object.entries(c).sort((a,b)=>b[1]-a[1]).map(([k,v])=>({k,v}));
