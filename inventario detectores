/* Huecos de consecutivo por lazo (lógica inteligente) */
function renderGaps(){
  if(S.nivel){ $('gapInfo').textContent=''; return; }
  let gaps=0;
  ['L01','L02','L03','L04','L05','L06'].forEach(L=>{
    ['D','M'].forEach(T=>{
      const nums=DB.devices.filter(d=>d.lazo===L&&new RegExp('^'+L.replace('0','0?')+T).test(d.dir.replace(/^L(\d)([DM])/, 'L0$1$2'))).map(d=>{const m=d.dir.match(/[DM](\d+)/);return m?+m[1]:0;});
      if(nums.length){ const max=Math.max(...nums); gaps += max-new Set(nums).size; }
    });
  });
  $('gapInfo').textContent = gaps>0?`Direcciones libres detectadas en consecutivos de lazo: ${gaps} (disponibles para nuevos dispositivos)`:'';
}

