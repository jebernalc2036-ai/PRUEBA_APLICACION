<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SDI Club El Nogal — Sistema de Detección de Incendios</title>
<style>
/* =====================================================================
   CORPORACIÓN CLUB EL NOGAL — SISTEMA DE DETECCIÓN DE INCENDIOS (SDI)
   Uso Interno Restringido · Sede Social · NFPA 72 / ISO 22340:2024
   Diseño: consola de central de monitoreo — tema oscuro operativo
   ===================================================================== */
:root{
  --bg:#0e1216; --surface:#151b22; --surface2:#1b232c; --line:#28323d; --line2:#33404d;
  --text:#e8edf1; --muted:#8fa0ae; --faint:#5d6b77;
  --ok:#3fb27f; --warn:#f0a840; --alarm:#e5484d; --info:#4a9edb;
  --l01:#d2622a; --l02:#4a9edb; --l03:#9b6dd6; --l04:#3fb27f; --l05:#e0b13e; --l06:#d65c8a; --lpanel:#8fa0ae;
  --mono:ui-monospace,'Cascadia Mono','JetBrains Mono',Consolas,monospace;
  --sans:'Segoe UI',system-ui,Roboto,'Helvetica Neue',Arial,sans-serif;
  --r:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-size:14px;line-height:1.45}
button{font-family:inherit;cursor:pointer}
input,select,textarea{font-family:inherit;font-size:13px;background:var(--bg);border:1px solid var(--line2);color:var(--text);border-radius:6px;padding:7px 9px;outline:none}
input:focus,select:focus,textarea:focus{border-color:var(--info)}
::placeholder{color:var(--faint)}
a{color:var(--info)}

/* ---------- LED estado (elemento firma) ---------- */
.led{display:inline-block;width:9px;height:9px;border-radius:50%;vertical-align:middle;box-shadow:0 0 6px currentColor}
.led.ok{color:var(--ok);background:var(--ok)} .led.warn{color:var(--warn);background:var(--warn)}
.led.alarm{color:var(--alarm);background:var(--alarm)} .led.off{color:var(--faint);background:var(--faint);box-shadow:none}

/* ---------- Login ---------- */
#loginView{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}
.loginCard{width:100%;max-width:420px;background:var(--surface);border:1px solid var(--line);border-radius:12px;padding:34px 32px}
.loginCard h1{font-size:19px;font-weight:600;letter-spacing:.4px}
.loginCard .sub{color:var(--muted);font-size:12px;margin:6px 0 4px}
.classif{display:inline-block;font-size:10px;letter-spacing:1.4px;color:var(--warn);border:1px solid var(--warn);border-radius:4px;padding:2px 8px;margin:10px 0 20px}
.field{margin-bottom:13px}
.field label{display:block;font-size:11px;color:var(--muted);letter-spacing:.6px;text-transform:uppercase;margin-bottom:5px}
.field input,.field select,.field textarea{width:100%}
.btn{background:var(--surface2);border:1px solid var(--line2);color:var(--text);padding:8px 15px;border-radius:6px;font-size:13px;transition:background .15s}
.btn:hover{background:var(--line)}
.btn.primary{background:#1e4d63;border-color:#2a6a88}
.btn.primary:hover{background:#25607c}
.btn.danger{background:#5a2328;border-color:#7c3036}
.btn.danger:hover{background:#6e2b31}
.btn.ok{background:#1e4d3a;border-color:#2a6a52}
.btn.ok:hover{background:#25604a}
.btn.sm{padding:4px 10px;font-size:12px}
.btn.block{width:100%}
.err{color:var(--alarm);font-size:12px;min-height:16px;margin-top:8px}
.panelStrip{height:5px;border-radius:3px 3px 0 0;background:linear-gradient(90deg,var(--l01),var(--l02),var(--l03),var(--l04),var(--l05),var(--l06));margin:-34px -32px 26px}

/* ---------- Shell ---------- */
#appView{display:none;min-height:100vh}
header.top{position:sticky;top:0;z-index:40;background:var(--surface);border-bottom:1px solid var(--line);padding:0 18px;display:flex;align-items:center;gap:14px;height:56px}
header.top .brand{font-weight:600;font-size:14.5px;letter-spacing:.3px;white-space:nowrap}
header.top .brand small{display:block;font-weight:400;font-size:10px;color:var(--muted);letter-spacing:.8px}
header.top .lazoBar{display:flex;gap:5px;margin-left:6px}
header.top .lazoBar span{width:22px;height:5px;border-radius:2px}
.spacer{flex:1}
.userBox{text-align:right;font-size:12px}
.userBox b{font-size:12.5px}
.userBox .rol{color:var(--muted);font-size:10.5px;letter-spacing:.6px}
.tag{font-size:10px;letter-spacing:1px;color:var(--warn);border:1px solid var(--warn);border-radius:4px;padding:1px 7px}

.layout{display:flex;min-height:calc(100vh - 56px)}
nav.side{width:198px;background:var(--surface);border-right:1px solid var(--line);padding:14px 10px;flex-shrink:0}
nav.side button{display:flex;align-items:center;gap:9px;width:100%;text-align:left;background:none;border:none;color:var(--muted);padding:9px 11px;border-radius:6px;font-size:13px;margin-bottom:2px}
nav.side button:hover{background:var(--surface2);color:var(--text)}
nav.side button.active{background:var(--surface2);color:var(--text);border-left:3px solid var(--info);padding-left:8px}
nav.side .navBadge{margin-left:auto;background:var(--alarm);color:#fff;font-size:10px;border-radius:9px;padding:1px 6px;min-width:17px;text-align:center}
main.content{flex:1;padding:20px 22px;min-width:0}
h2.viewTitle{font-size:16px;font-weight:600;margin-bottom:3px}
.viewSub{color:var(--muted);font-size:12px;margin-bottom:16px}

/* ---------- KPI / Dashboard ---------- */
.kpiGrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:11px;margin-bottom:18px}
.kpi{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:13px 15px}
.kpi .v{font-size:23px;font-weight:600;font-family:var(--mono)}
.kpi .l{font-size:11px;color:var(--muted);letter-spacing:.4px;margin-top:2px}
.kpi.aOk .v{color:var(--ok)} .kpi.aWarn .v{color:var(--warn)} .kpi.aAlarm .v{color:var(--alarm)} .kpi.aInfo .v{color:var(--info)}
.chartGrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:13px}
.card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:15px 16px}
.card h3{font-size:12.5px;font-weight:600;letter-spacing:.5px;color:var(--muted);text-transform:uppercase;margin-bottom:12px}
.legendRow{display:flex;flex-wrap:wrap;gap:10px;font-size:11px;color:var(--muted);margin-top:9px}
.legendRow i{display:inline-block;width:10px;height:10px;border-radius:2px;margin-right:4px;vertical-align:-1px}

/* ---------- Filtros / chips ---------- */
.toolbar{display:flex;flex-wrap:wrap;gap:8px;align-items:center;margin-bottom:11px}
.toolbar input[type=search]{min-width:220px;flex:1;max-width:340px}
.chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
.chip{background:var(--surface2);border:1px solid var(--line2);border-radius:14px;padding:3px 10px;font-size:11.5px;display:inline-flex;align-items:center;gap:6px}
.chip b{color:var(--info);font-weight:500}
.chip button{background:none;border:none;color:var(--muted);font-size:13px;padding:0;line-height:1}
.chip button:hover{color:var(--alarm)}

/* ---------- Niveles ---------- */
.nivTabs{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.nivTabs button{background:var(--surface);border:1px solid var(--line);color:var(--muted);border-radius:6px;padding:5px 10px;font-size:12px}
.nivTabs button:hover{color:var(--text)}
.nivTabs button.active{background:var(--surface2);color:var(--text);border-color:var(--info)}
.nivTabs button .cnt{font-family:var(--mono);font-size:10.5px;color:var(--faint);margin-left:4px}

/* ---------- Tabla ---------- */
.tableWrap{background:var(--surface);border:1px solid var(--line);border-radius:var(--r);overflow:auto;max-height:64vh}
table{width:100%;border-collapse:collapse;font-size:12.5px;min-width:960px}
thead th{position:sticky;top:0;background:var(--surface2);color:var(--muted);font-weight:600;font-size:11px;letter-spacing:.5px;text-transform:uppercase;text-align:left;padding:9px 10px;border-bottom:1px solid var(--line2);cursor:pointer;user-select:none;white-space:nowrap;z-index:5}
thead th .arrow{color:var(--info);font-size:10px}
tbody td{padding:7px 10px;border-bottom:1px solid var(--line);vertical-align:middle;white-space:nowrap}
tbody tr:hover{background:var(--surface2)}
tbody tr.rAlarm{background:rgba(229,72,77,.09)}
tbody tr.rWarn{background:rgba(240,168,64,.07)}
td.mono,.mono{font-family:var(--mono);font-size:12px}
.lazoDot{display:inline-block;width:8px;height:8px;border-radius:2px;margin-right:6px;vertical-align:-.5px}
.pill{display:inline-block;font-size:10.5px;padding:2px 8px;border-radius:10px;border:1px solid}
.pill.hab{color:var(--ok);border-color:var(--ok)} .pill.des{color:var(--alarm);border-color:var(--alarm)}
.pill.crit{color:var(--alarm);border-color:var(--alarm)} .pill.med{color:var(--warn);border-color:var(--warn)} .pill.nor{color:var(--muted);border-color:var(--line2)}
.novTxt{color:var(--warn);font-size:11.5px;max-width:220px;overflow:hidden;text-overflow:ellipsis;display:inline-block;vertical-align:middle}
.rowBtns button{background:none;border:none;color:var(--muted);font-size:14px;padding:2px 5px}
.rowBtns button:hover{color:var(--text)}
.pager{display:flex;align-items:center;gap:10px;margin-top:10px;font-size:12px;color:var(--muted);flex-wrap:wrap}

/* ---------- Verificación (ronda) ---------- */
.progressBar{height:8px;background:var(--surface2);border-radius:4px;overflow:hidden;margin:8px 0 14px}
.progressBar i{display:block;height:100%;background:var(--ok);transition:width .2s}
.rondaItem{display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--line);border-radius:var(--r);padding:11px 14px;margin-bottom:7px;flex-wrap:wrap}
.rondaItem .addr{font-family:var(--mono);font-size:13px;min-width:130px}
.rondaItem .desc{flex:1;min-width:200px}
.rondaItem .desc small{color:var(--muted);display:block}
.rondaItem.done{opacity:.55}

/* ---------- Alertas ---------- */
.alertItem{display:flex;gap:12px;align-items:flex-start;background:var(--surface);border:1px solid var(--line);border-left:3px solid var(--warn);border-radius:var(--r);padding:11px 14px;margin-bottom:8px}
.alertItem.sevAlarm{border-left-color:var(--alarm)}
.alertItem.sevInfo{border-left-color:var(--info)}
.alertItem .aT{font-weight:600;font-size:13px}
.alertItem .aD{color:var(--muted);font-size:12px;margin-top:2px}

/* ---------- Bitácora ---------- */
.logRow{font-size:12px;padding:7px 10px;border-bottom:1px solid var(--line);display:grid;grid-template-columns:150px 110px 90px 1fr;gap:10px}
.logRow .lw{color:var(--muted);font-family:var(--mono);font-size:11px}

/* ---------- Modal ---------- */
.modalBack{position:fixed;inset:0;background:rgba(5,8,11,.72);display:none;align-items:flex-start;justify-content:center;z-index:100;overflow:auto;padding:34px 14px}
.modalBack.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--line2);border-radius:12px;width:100%;max-width:680px;padding:22px 24px}
.modal h3{font-size:15px;margin-bottom:14px}
.formGrid{display:grid;grid-template-columns:1fr 1fr;gap:11px 14px}
.formGrid .full{grid-column:1/-1}
.modalBtns{display:flex;gap:9px;justify-content:flex-end;margin-top:18px}
.hint{font-size:11px;color:var(--faint);margin-top:3px}

/* ---------- Toast ---------- */
#toast{position:fixed;bottom:22px;right:22px;z-index:200;display:flex;flex-direction:column;gap:8px}
.toastMsg{background:var(--surface2);border:1px solid var(--line2);border-left:3px solid var(--ok);border-radius:8px;padding:10px 15px;font-size:13px;box-shadow:0 6px 20px rgba(0,0,0,.4);animation:tIn .2s}
.toastMsg.e{border-left-color:var(--alarm)} .toastMsg.w{border-left-color:var(--warn)}
@keyframes tIn{from{transform:translateY(8px);opacity:0}}

/* ---------- Config ---------- */
.catList{display:flex;flex-wrap:wrap;gap:6px;margin:8px 0 12px}
.catList .chip button{margin-left:2px}

/* ---------- Print (reporte institucional) ---------- */
.printHead{display:none}
@media print{
  body{background:#fff;color:#000;font-size:11px}
  header.top,nav.side,.toolbar,.pager,.nivTabs,.rowBtns,#toast,.modalBack,.noPrint{display:none!important}
  .layout{display:block} main.content{padding:0}
  .printHead{display:block;border-bottom:2px solid #000;margin-bottom:12px;padding-bottom:8px}
  .printHead h1{font-size:14px} .printHead p{font-size:10px;color:#333}
  .tableWrap{max-height:none;overflow:visible;border:none}
  table{min-width:0} thead th{position:static;background:#eee;color:#000}
  tbody tr.rAlarm{background:#fdd} tbody tr.rWarn{background:#fef3d8}
  .card,.kpi{border:1px solid #999;background:#fff}
  .kpi .v{color:#000!important}
}

/* ---------- Responsive ---------- */
@media (max-width:860px){
  nav.side{width:56px}
  nav.side button span.lbl{display:none}
  nav.side button{justify-content:center;padding:10px 0}
  nav.side button.active{padding-left:0;border-left:none;border-bottom:2px solid var(--info)}
  header.top .brand small{display:none}
  .formGrid{grid-template-columns:1fr}
  .logRow{grid-template-columns:1fr;gap:2px}
}
@media (prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
<body>

<!-- ============================ LOGIN ============================ -->
<div id="loginView">
  <div class="loginCard">
    <div class="panelStrip"></div>
    <h1>Sistema de Detección de Incendios</h1>
    <div class="sub">Corporación Club El Nogal · Sede Social · Bogotá D.C.</div>
    <span class="classif">USO INTERNO RESTRINGIDO</span>
    <div id="loginForm">
      <div class="field"><label>Correo institucional</label><input id="liMail" type="email" placeholder="usuario@clubelnogal.com" autocomplete="username"></div>
      <div class="field"><label>Contraseña</label><input id="liPass" type="password" autocomplete="current-password"></div>
      <button class="btn primary block" onclick="doLogin()">Iniciar sesión</button>
      <div class="err" id="liErr"></div>
      <p style="font-size:12px;color:var(--muted);margin-top:12px">¿Sin cuenta? <a href="#" onclick="toggleReg(true);return false">Registrar usuario</a></p>
    </div>
    <div id="regForm" style="display:none">
      <div class="field"><label>Nombre completo</label><input id="rgNom" type="text"></div>
      <div class="field"><label>Correo institucional</label><input id="rgMail" type="email" placeholder="usuario@clubelnogal.com"></div>
      <div class="field"><label>Contraseña (mín. 6 caracteres)</label><input id="rgPass" type="password"></div>
      <div class="field"><label>Rol solicitado</label>
        <select id="rgRol"><option>CONSULTA</option><option>SUPERVISOR</option><option>ADMINISTRADOR</option></select>
      </div>
      <button class="btn primary block" onclick="doRegister()">Crear cuenta</button>
      <div class="err" id="rgErr"></div>
      <p style="font-size:12px;color:var(--muted);margin-top:12px"><a href="#" onclick="toggleReg(false);return false">← Volver al inicio de sesión</a></p>
    </div>
    <p style="font-size:10.5px;color:var(--faint);margin-top:18px">Inventario base: libro DETECTORES 2016 · Panel direccionable FlashScan · Lazos L01–L06 · NFPA 72 · ISO 22340:2024</p>
  </div>
</div>

<!-- ============================ APP ============================ -->
<div id="appView">
  <header class="top">
    <div class="brand">SDI · CLUB EL NOGAL<small>SISTEMA DE DETECCIÓN DE INCENDIOS — SEDE SOCIAL</small></div>
    <div class="lazoBar" title="Lazos SLC L01–L06">
      <span style="background:var(--l01)"></span><span style="background:var(--l02)"></span><span style="background:var(--l03)"></span>
      <span style="background:var(--l04)"></span><span style="background:var(--l05)"></span><span style="background:var(--l06)"></span>
    </div>
    <div class="spacer"></div>
    <button class="btn sm" id="syncChip" title="Estado de sincronización con archivo compartido OneDrive" onclick="syncChipClick()" style="display:flex;align-items:center;gap:6px"><span class="led off" id="syncLed"></span><span id="syncTxt">Solo local</span></button>
    <span class="tag">USO INTERNO RESTRINGIDO</span>
    <div class="userBox"><b id="hdUser"></b><div class="rol" id="hdRol"></div></div>
    <button class="btn sm" title="Cambiar mi contraseña" onclick="changePass()">🔑</button>
    <button class="btn sm" onclick="doLogout()">Salir</button>
  </header>

  <div class="layout">
    <nav class="side">
      <button data-v="dash" class="active" onclick="go('dash')">📊 <span class="lbl">Dashboard</span></button>
      <button data-v="inv" onclick="go('inv')">🗂 <span class="lbl">Inventario</span></button>
      <button data-v="ronda" onclick="go('ronda')">✅ <span class="lbl">Verificación</span></button>
      <button data-v="alert" onclick="go('alert')">🚨 <span class="lbl">Alertas</span><span class="navBadge" id="alertBadge" style="display:none">0</span></button>
      <button data-v="log" onclick="go('log')">📜 <span class="lbl">Bitácora</span></button>
      <button data-v="conf" onclick="go('conf')">⚙️ <span class="lbl">Configuración</span></button>
    </nav>

    <main class="content">
      <div class="printHead">
        <h1>CORPORACIÓN CLUB EL NOGAL — SISTEMA DE DETECCIÓN DE INCENDIOS · SEDE SOCIAL</h1>
        <p>Clasificación: Uso Interno Restringido · Marco: NFPA 72 / ISO 22340:2024 · Generado: <span id="prDate"></span> · Usuario: <span id="prUser"></span></p>
      </div>

      <!-- ===== DASHBOARD ===== -->
      <section id="v-dash">
        <h2 class="viewTitle">Dashboard ejecutivo</h2>
        <div class="viewSub">Indicadores en vivo del inventario SDI · <span id="dashStamp"></span></div>
        <div class="kpiGrid" id="kpiGrid"></div>
        <div class="chartGrid">
          <div class="card"><h3>Dispositivos por nivel</h3><div id="chNivel"></div></div>
          <div class="card"><h3>Estado operativo</h3><div id="chEstado"></div></div>
          <div class="card"><h3>Habilitado / Deshabilitado por lazo SLC</h3><div id="chLazo"></div></div>
          <div class="card"><h3>Distribución por tipo de dispositivo</h3><div id="chTipo"></div></div>
          <div class="card"><h3>Verificación de rondas (histórico)</h3><div id="chRondas"></div></div>
          <div class="card"><h3>Ubicaciones de criticidad ALTA con novedad o deshabilitadas</h3><div id="chCrit"></div></div>
        </div>
        <div style="margin-top:14px" class="noPrint"><button class="btn" onclick="printReport()">🖨 Imprimir / PDF reporte ejecutivo</button></div>
      </section>

      <!-- ===== INVENTARIO ===== -->
      <section id="v-inv" style="display:none">
        <h2 class="viewTitle">Inventario maestro</h2>
        <div class="viewSub" id="invSub"></div>
        <div class="nivTabs" id="nivTabs"></div>
        <div class="toolbar">
          <input type="search" id="q" placeholder="Buscar: dirección, ubicación, zona, observación…" oninput="S.page=1;renderInv()">
          <select id="fCat" onchange="S.page=1;renderInv()"><option value="">Categoría (todas)</option><option>DETECTOR</option><option>MODULO</option></select>
          <select id="fTipo" onchange="S.page=1;renderInv()"></select>
          <select id="fLazo" onchange="S.page=1;renderInv()"></select>
          <select id="fEstado" onchange="S.page=1;renderInv()"><option value="">Estado (todos)</option><option>HABILITADO</option><option>DESHABILITADO</option></select>
          <select id="fVerif" onchange="S.page=1;renderInv()"><option value="">Verificación</option><option value="1">Verificado</option><option value="0">Sin verificar</option></select>
          <select id="fNov" onchange="S.page=1;renderInv()"><option value="">Novedad</option><option value="1">Con novedad</option><option value="0">Sin novedad</option></select>
          <select id="fCrit" onchange="S.page=1;renderInv()"><option value="">Criticidad</option><option>ALTA</option><option>MEDIA</option><option>NORMAL</option></select>
          <button class="btn sm" onclick="clearFilters()">Limpiar</button>
          <span class="spacer"></span>
          <button class="btn sm primary" id="btnNew" onclick="openForm()">＋ Nuevo dispositivo</button>
          <button class="btn sm" onclick="exportCSV()">⬇ CSV</button>
          <button class="btn sm" onclick="exportJSON()">⬇ JSON</button>
          <button class="btn sm" onclick="printReport()">🖨</button>
        </div>
        <div class="chips" id="activeChips"></div>
        <div class="tableWrap"><table id="tbl">
          <thead><tr>
            <th data-k="dir" onclick="sortBy('dir')">Dirección</th>
            <th data-k="lazo" onclick="sortBy('lazo')">Lazo</th>
            <th data-k="cat" onclick="sortBy('cat')">Cat.</th>
            <th data-k="tipo" onclick="sortBy('tipo')">Type Code</th>
            <th data-k="ubic" onclick="sortBy('ubic')">Ubicación</th>
            <th data-k="nivel" onclick="sortBy('nivel')">Nivel</th>
            <th data-k="torre" onclick="sortBy('torre')">Torre</th>
            <th data-k="cbe" onclick="sortBy('cbe')">Zonas CBE</th>
            <th data-k="crit" onclick="sortBy('crit')">Crit.</th>
            <th data-k="estado" onclick="sortBy('estado')">Estado</th>
            <th data-k="verif" onclick="sortBy('verif')">Verif.</th>
            <th data-k="nov" onclick="sortBy('nov')">Novedad</th>
            <th class="noPrint"></th>
          </tr></thead>
          <tbody id="tbody"></tbody>
        </table></div>
        <div class="pager">
          <span id="pgInfo"></span>
          <button class="btn sm" onclick="pg(-1)">‹ Anterior</button>
          <button class="btn sm" onclick="pg(1)">Siguiente ›</button>
