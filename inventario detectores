/* ---------- Motor de filtrado ---------- */
function filtered(){
  const q=($('q')?.value||'').toUpperCase();
  const f = {cat:$('fCat')?.value||'', tipo:$('fTipo')?.value||'', lazo:$('fLazo')?.value||'',
             est:$('fEstado')?.value||'', ver:$('fVerif')?.value||'', nov:$('fNov')?.value||'', crit:$('fCrit')?.value||''};
  return DB.devices.filter(d=>{
    if(S.nivel && d.nivel!==S.nivel) return false;
    if(f.cat && d.cat!==f.cat) return false;
    if(f.tipo && d.tipo!==f.tipo) return false;
    if(f.lazo && d.lazo!==f.lazo) return false;
    if(f.est && d.estado!==f.est) return false;
    if(f.ver!=='' && String(d.verif?1:0)!==f.ver) return false;
    if(f.nov!=='' && String(d.nov?1:0)!==f.nov) return false;
    if(f.crit && critOf(d)!==f.crit) return false;
    if(q){ const hay=(d.dir+' '+d.tipo+' '+d.label+' '+d.ubic+' '+d.obs+' '+d.cbe+' '+d.nivel+' '+d.nov+' '+d.motivo).toUpperCase(); if(!hay.includes(q)) return false; }
    return true;
  });
}

